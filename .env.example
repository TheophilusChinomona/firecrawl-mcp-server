# --- Firecrawl backend ----------------------------------------------------
# Self-hosted instance URL. Required for self-hosted; omit to use cloud Firecrawl.
FIRECRAWL_API_URL=https://crawl.theochinomona.tech

# Optional API key. Required when your self-hosted instance has USE_AUTH=true,
# or when calling cloud Firecrawl. Leave blank for an open self-hosted instance.
FIRECRAWL_API_KEY=

# --- LLM (used by enrich_* and research tools) ----------------------------
# OpenAI-compatible. Defaults to OpenRouter — change to OpenAI / a local LLM
# / any compatible gateway by swapping LLM_BASE_URL and LLM_API_KEY.
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1

# Models, addressed by tier. OpenRouter uses provider/model strings; OpenAI
# uses bare model names. The fire-enrich pipeline picks `smart` for synthesis
# and `fast` for cheap classification.
LLM_MODEL_SMART=anthropic/claude-sonnet-4-6
LLM_MODEL_FAST=anthropic/claude-haiku-4-5

# Backwards-compat aliases — code falls back to these if the LLM_* vars above
# are unset. Set OPENAI_API_KEY if you only have an OpenAI key and want
# everything to "just work".
OPENAI_API_KEY=
OPENAI_BASE_URL=

# --- Tool allowlist -------------------------------------------------------
# Optional comma-separated allowlist for the *custom* tools (research,
# enrich, fire_enrich_*, monitor, brand-audit, seo-audit). Stock Firecrawl
# tools (scrape, map, search, crawl, extract, browser_*) always register —
# they're the core of this MCP.
# Example: FIRE_ENRICH_TOOLS=firecrawl_research,fire_enrich_email
# Unset = every custom tool is registered.
FIRE_ENRICH_TOOLS=
